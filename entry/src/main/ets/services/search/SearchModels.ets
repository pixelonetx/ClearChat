/**
 * жҗңзҙўз»“жһңйЎ?
 */
export interface SearchResultItem {
  // з»“жһңж Үйўҳ
  title: string;
  
  // з»“жһң URL
  url: string;
  
  // з»“жһңж–Үжң¬/ж‘ҳиҰҒ
  text: string;
  
  // е”ҜдёҖ IDпјҲз”ЁдәҺеј•з”Ёпјү
  id?: string;
  
  // зҙўеј•еҸ·пјҲз”ЁдәҺеј•з”Ёпј?
  index?: number;
  
  // жқҘжәҗ
  source?: string;
}

/**
 * жҗңзҙўз»“жһң
 */
export interface SearchResult {
  // AI з”ҹжҲҗзҡ„зӯ”жЎҲж‘ҳиҰҒпјҲеҰӮжһңжҸҗдҫӣе•Ҷж”ҜжҢҒпјү
  answer?: string;
  
  // жҗңзҙўз»“жһңйЎ№еҲ—иЎ?
  items: SearchResultItem[];
  
  // еҺҹе§Ӣе“Қеә”пјҲз”ЁдәҺи°ғиҜ•пјү
  rawResponse?: Object;
  
  // жү§иЎҢж—¶й—ҙпјҲжҜ«з§’пјү
  executionTime?: number;
}

/**
 * йҖҡз”ЁжҗңзҙўйҖүйЎ№
 */
export interface SearchCommonOptions {
  // иҝ”еӣһз»“жһңж•°йҮҸ
  resultSize?: number;
  
  // и¶…ж—¶ж—¶й—ҙпјҲжҜ«з§’пјү
  timeout?: number;
}

/**
 * жҗңзҙўжңҚеҠЎй…ҚзҪ®еҹәзұ»
 */
export abstract class SearchServiceOptions {
  // жңҚеҠЎIDпјҲе”ҜдёҖж ҮиҜҶпј?
  id: string;
  
  // жңҚеҠЎзұ»еһӢ
  abstract type: string;
  
  constructor(id: string) {
    this.id = id;
  }
  
  abstract toJson(): Object;
  
  static fromJson(json: Object): SearchServiceOptions {
    const jsonObj = json as Record<string, Object | string | number | boolean | null>;
    const type = jsonObj['type'] as string;
    switch (type) {
      case 'tavily':
        return TavilyOptions.fromJson(json);
      case 'exa':
        return ExaOptions.fromJson(json);
      case 'zhipu':
        return ZhipuOptions.fromJson(json);
      case 'searxng':
        return SearXNGOptions.fromJson(json);
      case 'brave':
        return BraveOptions.fromJson(json);
      case 'metaso':
        return MetasoOptions.fromJson(json);
      case 'google_custom_search':
        return GoogleCustomSearchOptions.fromJson(json);
      default:
        throw new Error(`жңӘзҹҘзҡ„жҗңзҙўжңҚеҠЎзұ»еһ? ${type}`);
    }
  }
}

/**
 * Tavily жҗңзҙўжңҚеҠЎй…ҚзҪ®
 */
export class TavilyOptions extends SearchServiceOptions {
  type = 'tavily';
  
  // API Key
  apiKey: string;
  
  constructor(id: string, apiKey: string) {
    super(id);
    this.apiKey = apiKey;
  }
  
  toJson(): Object {
    const result: Record<string, Object | string> = {};
    result['type'] = this.type;
    result['id'] = this.id;
    result['apiKey'] = this.apiKey;
    return result;
  }
  
  static fromJson(json: Object): TavilyOptions {
    const jsonObj = json as Record<string, Object | string | number | boolean | null>;
    return new TavilyOptions(
      jsonObj['id'] as string,
      jsonObj['apiKey'] as string,
    );
  }
}

