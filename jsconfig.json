{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["entry/src/main/ets/*"]
    }
  },
  "include": [
    "**/*.ets",
    "**/*.ts",
    "**/*.js"
  ],
  "exclude": [
    "node_modules",
    "oh_modules",
    "**/build/**",
    ".hvigor"
  ]
}
